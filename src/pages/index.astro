---
const treatwellUrl = "https://laylaradestock.mytreatwell.co.uk/";
const instagramUrl = "https://www.instagram.com/foreveryoungbeauty_bylayla/";
const facebookUrl = "https://www.facebook.com/foreveryoungbeautybylayla/";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forever Young Beauty By Layla</title>
  <meta
    name="description"
    content="Professional beauty treatments with easy online booking through Treatwell."
  />
</head>

<body>
  <a class="floating-book" href={treatwellUrl} target="_blank">
    Book Now
  </a>

  <header class="hero">
    <div class="hero-content">
      <p class="eyebrow">Beauty • Confidence • Self Care</p>

      <h1>Forever Young Beauty By Layla</h1>

      <p class="intro">
        Professional beauty treatments with simple online booking.
        View availability and book instantly through Treatwell.
      </p>

      <div class="buttons">
        <a class="button" href={treatwellUrl} target="_blank">
          Book on Treatwell
        </a>

        <a class="button instagram" href={instagramUrl} target="_blank">
          Instagram
        </a>

        <a class="button facebook" href={facebookUrl} target="_blank">
          Facebook
        </a>
      </div>
    </div>
  </header>

  <section class="section">
    <h2>Popular Treatments</h2>

    <div class="grid">
      <div class="card">
        <h3>Facials</h3>
        <p>Refresh and rejuvenate your skin.</p>
      </div>

      <div class="card">
        <h3>Lashes & Brows</h3>
        <p>Enhance your natural beauty.</p>
      </div>

      <div class="card">
        <h3>Beauty Treatments</h3>
        <p>View all available services on Treatwell.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <h2>Why Choose Layla?</h2>

    <div class="grid">
      <div class="card">
        <h3>Professional</h3>
        <p>Friendly and professional service.</p>
      </div>

      <div class="card">
        <h3>Trusted</h3>
        <p>Online booking and verified reviews.</p>
      </div>

      <div class="card">
        <h3>Convenient</h3>
        <p>Book your appointment in minutes.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Follow Us</h2>

    <p>
      Keep up with our latest treatments, offers and beauty inspiration.
    </p>

    <div class="buttons">
      <a class="button instagram" href={instagramUrl} target="_blank">
        Instagram
      </a>

      <a class="button facebook" href={facebookUrl} target="_blank">
        Facebook
      </a>
    </div>
  </section>

  <footer>
    <p>© Forever Young Beauty By Layla</p>
  </footer>
</body>
</html>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #fff8fb;
  color: #2b2326;
}

.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24px;
  background: linear-gradient(135deg,#fff7fb,#f3bfd3);
}

.hero-content {
  max-width: 800px;
}

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 2px;
  font-weight: bold;
}

h1 {
  font-size: clamp(3rem,8vw,5rem);
  margin: 20px 0;
}

.intro {
  font-size: 1.2rem;
  margin-bottom: 30px;
}

.buttons {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.button {
  text-decoration: none;
  color: white;
  background: #2b2326;
  padding: 14px 24px;
  border-radius: 999px;
  font-weight: bold;
}

.instagram {
  background: #E1306C;
}

.facebook {
  background: #1877F2;
}

.section {
  max-width: 1100px;
  margin: auto;
  padding: 80px 24px;
  text-align: center;
}

.alt {
  background: white;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 20px;
  margin-top: 30px;
}

.card {
  background: white;
  padding: 30px;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,.08);
}

.floating-book {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #2b2326;
  color: white;
  text-decoration: none;
  padding: 14px 22px;
  border-radius: 999px;
  font-weight: bold;
}

footer {
  background: #2b2326;
  color: white;
  text-align: center;
  padding: 24px;
}

@media (max-width: 768px) {
  .grid {
    grid-template-columns: 1fr;
  }
}
</style>
